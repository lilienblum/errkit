{
  "name": "errkit",
  "version": "0.5.0",
  "description": "Declare errors once and generate TypeScript, Go, and Rust error code catalogs.",
  "keywords": [
    "errors",
    "error-codes",
    "codegen",
    "typescript",
    "go",
    "rust"
  ],
  "type": "module",
  "license": "MIT",
  "bin": {
    "errkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
